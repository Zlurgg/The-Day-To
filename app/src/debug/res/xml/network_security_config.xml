<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        DEBUG ONLY: Allow cleartext HTTP traffic for Firebase emulator.
        This config is only used in debug builds (app/src/debug/).
        Release builds use the default secure configuration.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
